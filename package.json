{
  "name": "signal-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npm run test:mailer && npm run test:transcripts && npm run test:options-report && npm run test:leverage",
    "dev": "node --env-file=.env server/server.js",
    "build": "vite build",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/server.js",
    "backfill:sec": "node --env-file=.env server/scripts/backfillSec.js",
    "backfill:mcp": "node --env-file=.env server/scripts/backfillMcp.js",
    "backfill:github-stars": "node --env-file=.env server/scripts/backfillGithubStars.js",
    "backfill:gpu-history": "node --env-file=.env server/scripts/backfillGpuHistory.js",
    "backfill:dram": "node --env-file=.env server/scripts/backfillDram.js",
    "backfill:nand": "node --env-file=.env server/scripts/backfillTrendforcePrice.js nand",
    "backfill:tft-lcd": "node --env-file=.env server/scripts/backfillTrendforcePrice.js tft-lcd",
    "backfill:korea-leverage": "node --env-file=.env server/scripts/backfillKoreaLeverage.js",
    "backfill:taiwan-leverage": "node --env-file=.env server/scripts/backfillTaiwanLeverage.js",
    "backfill:aws-spot": "node --env-file=.env server/scripts/backfillAwsSpot.js",
    "backfill:cpu-spot": "node --env-file=.env server/scripts/backfillCpuSpot.js",
    "backfill:transcripts:alpha": "node --env-file=.env server/scripts/backfillAlphaVantageTranscripts.js",
    "enrich:transcripts": "node --env-file=.env server/scripts/enrichTranscripts.js",
    "embed:transcripts": "server/.venv-transcripts/bin/python server/retrieval/chroma_pipeline.py index",
    "query:transcripts": "server/.venv-transcripts/bin/python server/retrieval/chroma_pipeline.py query",
    "tone:transcripts:local": "server/.venv-transcripts/bin/python server/retrieval/tone_pipeline.py",
    "tone:transcripts:llm": "node --env-file=.env server/scripts/interpretTranscriptTone.js",
    "facts:transcripts": "node --env-file=.env server/scripts/extractTranscriptFacts.js",
    "figures:transcripts": "node --env-file=.env server/scripts/extractKeyFigures.js",
    "analyze:transcripts": "npm run tone:transcripts:local && npm run tone:transcripts:llm && npm run facts:transcripts && npm run figures:transcripts",
    "publish:transcripts": "node --env-file=.env server/scripts/publishTranscriptsToMongo.js",
    "pipeline:transcripts": "node server/scripts/runTranscriptPipeline.mjs",
    "backfill:all": "npm run backfill:sec && npm run backfill:mcp && npm run backfill:github-stars",
    "db:ping": "node --env-file=.env server/scripts/dbPing.js",
    "db:seed": "node --env-file=.env server/scripts/seedMongo.js",
    "db:seed:dc": "node --env-file=.env server/scripts/seedDcBuildouts.js",
    "collect": "node --env-file=.env server/scripts/collect.js",
    "options-report:generate": "node --env-file-if-exists=.env server/scripts/generateAndStoreDailyOptionsReport.js",
    "options-report:send": "node --env-file-if-exists=.env server/scripts/sendDailyOptionsReport.js",
    "weekly-report:generate": "node --env-file-if-exists=.env server/scripts/generateWeeklyReport.js",
    "weekly-report:send": "node --env-file-if-exists=.env server/scripts/sendWeeklyReport.js",
    "test:transcripts": "node --test server/transcripts/*.test.js server/transcripts/*.test.mjs",
    "test:mailer": "node --test server/mailer.test.js",
    "test:options-report": "node --test server/earningsDates.test.js server/optionsReportChart.test.js server/optionsScraper.test.js",
    "test:leverage": "node --test server/scrapers/taiwanLeverage.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-pricing": "^3.1069.0",
    "@e965/xlsx": "^0.20.3",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "axios": "^1.17.0",
    "chart.js": "^4.4.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-trends-api": "^4.9.2",
    "groq-sdk": "^0.9.0",
    "mongodb": "^7.3.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "yahoo-finance2": "^3.15.2"
  },
  "devDependencies": {
    "@aws-sdk/client-ec2": "^3.1068.0",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.4.0"
  }
}
