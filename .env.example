# ── Persistence ────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. When set, all accumulated history
# (metricsHistory, gpuHistory, dramHistory) is stored in Mongo instead of local
# JSON files — required on Render's free tier, whose filesystem is ephemeral.
# On first boot the server seeds Mongo from the committed JSON baseline.
# Leave unset locally to use the JSON files as before.
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/signal_dashboard?retryWrites=true&w=majority
# Optional: override the database name (otherwise taken from the URI path).
# MONGODB_DB=signal_dashboard

# ── API keys (all optional; features degrade gracefully without them) ─────────
GROQ_API_KEY=            # Ask tab (chat) — groq.com
OPENROUTER_API_KEY=      # OpenRouter model rankings — openrouter.ai/keys
EIA_API_KEY=             # US electricity rates — eia.gov/opendata
GITHUB_TOKEN=            # raises GitHub API limits for MCP + stars scrapers
VAST_API_KEY=            # GPU history backfill (needs the machine_read permission group)
MASSIVE_API_KEY=         # Options chains, volume alerts & sentiment daily prices — massive.com

# Historical GPU spot prices from AWS EC2 (npm run backfill:aws-spot). A free,
# read-only key with ec2:DescribeSpotPriceHistory; fills ~90 days of real spot
# pricing for H100/H200/A100. Unset → the backfill no-ops.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Options proxy ────────────────────────────────────────────────────────────
# Yahoo Finance rate-limits Render's shared egress IPs, so the /api/options
# route 429s in production. Deploy api/options.js to Vercel (root vercel.json
# builds it) and set this to its URL — the server then fetches options chains
# through the proxy (a clean IP) instead of calling Yahoo directly. Leave unset
# locally to call
# Yahoo directly, which works fine from a laptop / Codespace.
# OPTIONS_PROXY_URL=https://your-proxy.vercel.app/api/options
# Optional shared secret — must match PROXY_SECRET set on the Vercel project so
# the open endpoint isn't abusable. Sent as the x-proxy-key header.
# PROXY_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=3001              # Render sets this automatically
# NODE_ENV=production    # set by the `npm start` script

# ── Options-volume email alerts (Alerts page) ───────────────────────────────
# Credentials used to send the "large call/put volume increase" alert emails.
# All optional: without them, subscriptions still save and the Alerts page's
# "Check now" preview works, but no email is actually delivered.
#
# Brevo transactional API (recommended once you have a Brevo account):
# ALERT_EMAIL_PROVIDER=brevo
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=        # verified Brevo sender/domain email
# BREVO_FROM_NAME=SIGNAL Alerts
# ALERT_FROM_EMAIL=        # optional: "SIGNAL Alerts <alerts@yourdomain.com>"
#
# SMTP fallback/relay. For Brevo SMTP, use:
#   ALERT_EMAIL_PROVIDER=smtp
#   SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   SMTP_USER=<brevo-smtp-login>    SMTP_PASS=<brevo-smtp-key>
# For Gmail, create an App Password (myaccount.google.com/apppasswords) and use:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
# ALERT_EMAIL_PROVIDER=     # "brevo" or "smtp"; auto-selects Brevo when BREVO_API_KEY is set
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=
# BREVO_FROM_NAME=
# SMTP_HOST=
# SMTP_PORT=587            # 465 for implicit TLS
# SMTP_SECURE=             # "true" to force TLS (auto-on for port 465)
# SMTP_USER=
# SMTP_PASS=
# ALERT_FROM_EMAIL=        # "SIGNAL Alerts <you@gmail.com>" — defaults to SMTP_USER
#
# Add the same values plus MONGODB_URI and MASSIVE_API_KEY as GitHub repository
# secrets so .github/workflows/options-alerts.yml can send while the web app sleeps.
