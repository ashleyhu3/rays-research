# ── Persistence ────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. When set, all accumulated history
# (metricsHistory, gpuHistory, dramHistory) is stored in Mongo instead of local
# JSON files — required on Render's free tier, whose filesystem is ephemeral.
# On first boot the server seeds Mongo from the committed JSON baseline.
# Leave unset locally to use the JSON files as before.
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/signal_dashboard?retryWrites=true&w=majority
# Optional: override the database name (otherwise taken from the URI path).
# MONGODB_DB=signal_dashboard

# ── API keys (all optional; features degrade gracefully without them) ─────────
GROQ_API_KEY=            # Ask tab (chat) — groq.com
OPENROUTER_API_KEY=      # OpenRouter model rankings — openrouter.ai/keys
EIA_API_KEY=             # US electricity rates — eia.gov/opendata
GITHUB_TOKEN=            # raises GitHub API limits for MCP + stars scrapers
VAST_API_KEY=            # GPU history backfill (needs the machine_read permission group)

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=3001              # Render sets this automatically
# NODE_ENV=production    # set by the `npm start` script
